PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/curalink
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
PUBMED_TOOL=curalink_research
PUBMED_EMAIL=you@example.com
# Faster CPU demos: smaller retrieval, skips extra LLM query-expansion. Use 0 or full for max depth.
CURALINK_FAST_MODE=1
# Optional: absolute or cwd-relative path to Vite `dist` for single-host deploy
# FRONTEND_DIST=../frontend/dist
