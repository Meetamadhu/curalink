PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/curalink
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
PUBMED_TOOL=curalink_research
PUBMED_EMAIL=you@example.com
# Faster CPU demos: smaller retrieval, skips extra LLM query-expansion and semantic embedding rerank.
CURALINK_FAST_MODE=1
# Semantic reranking (Sentence Transformers via @xenova/transformers). Off when CURALINK_FAST_MODE=1.
# CURALINK_EMBEDDINGS=1
# Preset: minilm | bge-small | e5-small | instructor-xl  (or set CURALINK_EMBEDDING_MODEL to any Xenova Hub id)
# CURALINK_EMBEDDING_PRESET=minilm
# Blend: semantic weight vs lexical (0–1). Default 0.55
# CURALINK_EMBEDDING_WEIGHT=0.55
# How many top lexical candidates to rerank per list (16–160). Default 64
# CURALINK_EMBEDDING_POOL=64
# Optional: absolute or cwd-relative path to Vite `dist` for single-host deploy
# FRONTEND_DIST=../frontend/dist
